# 复制为 .env 后填写实际值（.env 不入库）

# PostgreSQL（与 docker-compose.dev.yml 默认值一致）
DATABASE_URL="postgresql://ski:ski_dev_password@localhost:5432/ski?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# API 服务端口
API_PORT=3000

# Web（Next.js）：后端 API 地址与站点对外 URL（sitemap/robots 用）
API_URL="http://localhost:3000"
SITE_URL="http://localhost:3001"

# 和风天气（https://dev.qweather.com 注册后获取）
# QWEATHER_API_HOST 为控制台分配的专属 API Host，形如 https://xxxx.re.qweatherapi.com
QWEATHER_API_KEY=""
QWEATHER_API_HOST=""

# ---- 以下仅生产部署（docker-compose.prod.yml）需要 ----
# 生产库密码（自定义一个强密码）
POSTGRES_PROD_PASSWORD=""
# Cloudflare Zero Trust -> Networks -> Tunnels 创建后获得的 token
CLOUDFLARE_TUNNEL_TOKEN=""
